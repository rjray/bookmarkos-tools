#!/usr/bin/env bash

umask 0022

# Do we have Linuxbrew set up?
if [ -d /home/linuxbrew/.linuxbrew ]; then
    eval $(/home/linuxbrew/.linuxbrew/bin/brew shellenv)
fi

sourcedir="$HOME/Dropbox/Apps/Bookmark OS"
datadir="$HOME/data/BookmarkOS"
date=$(date +"%Y%m%d")
html="$datadir/bookmarks-$date.html.gz"
json="$datadir/bookmarks-$date.json.gz"

gzip -c -9 "$sourcedir/backup.html" > $html && bookmarks2json --input $html --output $json

bookmarks_report weekly $json | \
  mailx -s "Weekly Bookmarks Report" rjray@blackperl.com
